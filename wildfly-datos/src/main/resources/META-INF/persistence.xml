<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="examPU" transaction-type="JTA">
        <jta-data-source>java:/jdbc/ExamDS</jta-data-source>
        <class>com.taller.datos.entity.exam.Question</class>
        <class>com.taller.datos.entity.exam.ExamAttempt</class>
        <class>com.taller.datos.entity.exam.Answer</class>
        <class>com.taller.datos.entity.exam.Evaluation</class>
        <class>com.taller.datos.entity.exam.OutboxEvent</class>
        <properties>
            <property name="hibernate.hbm2ddl.auto" value="none"/>
            <property name="hibernate.show_sql" value="false"/>
            <property name="hibernate.format_sql" value="true"/>
        </properties>
    </persistence-unit>

    <persistence-unit name="studentPU" transaction-type="JTA">
        <jta-data-source>java:/jdbc/StudentDS</jta-data-source>
        <class>com.taller.datos.entity.student.Student</class>
        <class>com.taller.datos.entity.student.Grade</class>
        <class>com.taller.datos.entity.student.ResultHistory</class>
        <properties>
            <property name="hibernate.hbm2ddl.auto" value="none"/>
            <property name="hibernate.show_sql" value="false"/>
            <property name="hibernate.format_sql" value="true"/>
        </properties>
    </persistence-unit>
</persistence>
